MODELS_TOKEN=your_models_or_openrouter_token_here
# Optional model selection for local runs or custom providers.
BUMPKIN_MODEL=openai/gpt-4.1-mini
BUMPKIN_FALLBACK_MODEL=
# Leave empty for the default path. Set this only for a custom provider.
BUMPKIN_MODELS_ENDPOINT=
GITHUB_TOKEN=your_github_token_here

# Experimental GitHub App shell runtime.
# This is intentionally not part of the primary OSS Action setup.

# Optional self-hosted app runtime.
# You do not need these for the main release-scoped GitHub Action flow.
BUMPKIN_APP_MODE=shell
BUMPKIN_APP_WEBHOOK_SECRET=replace-with-random-webhook-secret
# App shell mode dispatches the existing workflow and does not require a Bumpkin DB.
BUMPKIN_APP_RELEASE_WORKFLOW_FILE=.github/workflows/bumpkin.yml
# Optional if the workflow should dispatch on a specific branch; otherwise the repo default branch is used.
# BUMPKIN_APP_RELEASE_WORKFLOW_REF=main
# Provide either GitHub App credentials or a token that can dispatch Actions workflows.
BUMPKIN_APP_GITHUB_APP_ID=
BUMPKIN_APP_GITHUB_PRIVATE_KEY=
BUMPKIN_APP_PROVIDER_TOKEN=

# Legacy control-plane mode only.
# Set BUMPKIN_APP_MODE=legacy if you intentionally want the older DB-backed webhook runtime.
BUMPKIN_APP_DB_PATH=./artifacts/app/bumpkin.sqlite3
# Optional: use this instead of BUMPKIN_APP_DB_PATH in legacy mode if you already have Postgres.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
BUMPKIN_LICENSE_KEY=optional-commercial-license-key
BUMPKIN_APP_FEATURE_PRIVATE_AUTOMATION=false
BUMPKIN_APP_INGRESS_TIMEOUT_SECONDS=15
